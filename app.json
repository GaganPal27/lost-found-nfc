{
  "expo": {
    "name": "lost-found-nfc",
    "slug": "lost-found-nfc",
    "version": "1.0.0",
    "scheme": "lostfoundnfc",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lostandfound.nfc",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "bluetooth-central"
        ],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Lost & Found needs background location to silently relay lost item locations.",
        "NSLocationWhenInUseUsageDescription": "Lost & Found needs location to note where an item was found.",
        "NSBluetoothAlwaysUsageDescription": "Lost & Found uses Bluetooth to detect nearby beacons."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.lostandfound.nfc",
      "permissions": [
        "android.permission.NFC",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Allow Lost & Found to scan NFC tags to register or find items."
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": [
            "central"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Lost & Found to use your location to record where items were tapped or detected."
        }
      ]
    ]
  }
}
